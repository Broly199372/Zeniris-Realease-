# 🇧🇷 Zeniris — Tutorial

## Instalação
curl -fsSL https://raw.githubusercontent.com/Broly199372/Zeniris-Realease-/main/install.sh | bash
source ~/.bashrc

## Criando um projeto
zen_new meu_jogo

Estrutura criada:
meu_jogo/
  main.zn
  propriet.zn
  assets/
  mods/

## propriet.zn
nomemod = Meu Jogo
versao = 1.0.0
descricao = Meu primeiro jogo
autor = SeuNome

## Estrutura básica
Todo arquivo começa com Inicio e termina com Fim:
Inicio

Fim

## Variáveis
Inicio

Vida = 100;
Velocidade = 5,5;
Ativo = true;

100;     → inteiro
5,5;     → decimal
true;    → booleano verdadeiro
false;   → booleano falso

## Classes
Inicio

Classe Jogador

Fim

## Functions
Classe Jogador

Function Pular

Jogador.Pulando = On

Fim

Fim

## Estados
Sempre On ou Off:
Jogador.Vivo = On
Jogador.Morto = Off

## Dependências
Function Correr
Dep Jogador on1

Jogador.Movendo = On

Fim

on1 significa que o primeiro estado do Dep precisa estar On.
on2 significa que os dois primeiros precisam estar On. E assim por diante.

## Eventos
Evento JogadorAtingido

Jogador.Ferido = On

Fim

## Exemplo completo
Inicio

Vida = 100;
Velocidade = 5,5;

Classe Jogador

Function Iniciar

Jogador.Vivo = On

Fim

Function Correr
Dep Jogador on1

Jogador.Movendo = On

Fim

Function Morrer
Dep Jogador on2

Jogador.Vivo = Off
Jogador.Morto = On

Fim

Evento JogadorAtingido

Jogador.Ferido = On

Fim

Fim

## Compilar
zen_build meu_jogo/main.zn

## Rodar
zen_run meu_jogo

## Diagnosticar erros
zeniris diag meu_jogo/main.zn

## Exportar
zen_apk meu_jogo
zen_desktop meu_jogo
zen_desktop meu_jogo --windows


